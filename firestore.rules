rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{path=**}/reviews/{reviewId} {
      allow read: if request.auth != null;
    }

    match /users/{uid} {
      allow read: if true;
      allow create: if request.auth.uid == uid
        && !request.resource.data.keys().hasAny(['isBanned', 'bannedAt', 'bannedReason', 'gaqpCertified', 'gaqpCertifiedAt']);
      // 5/27 #96: 本人は gaqp* を触れない。admin のみ gaqpCertified / gaqpCertifiedAt を更新可
      allow update: if (request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isBanned', 'bannedAt', 'bannedReason', 'gaqpCertified', 'gaqpCertifiedAt']))
        || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['gaqpCertified', 'gaqpCertifiedAt']));
    }

    match /fishListings/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'farmer';

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid;
        // 5/27 #99: listing farmer は全フィールド更新可（既存・replyText 等）
        //          + 多段スレッドで自分の child reply を取り消したいケースのため、
        //          コメント送信者本人は isDeleted / deletedAt のみ更新可
        // 6/3 #119: 質問起点の取り消し（スレッドごと削除）で threadDeleted フラグも許可（送信者本人）。
        //          子返信・legacy返信の連鎖削除はサーバ（functions=admin）が代行。
        // 6/3 #121: 運営（admin）は連絡先マスク発動投稿を「非表示にする」ため全フィールド更新可。
        allow update: if request.auth != null
          && (get(/databases/$(database)/documents/fishListings/$(id)).data.farmerId == request.auth.uid
              || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
              || (resource.data.senderId == request.auth.uid
                  && request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['isDeleted', 'deletedAt', 'threadDeleted'])));
      }
    }

    match /orders/{id} {
      allow read: if request.auth != null
        && (resource.data.farmerId == request.auth.uid
         || resource.data.restaurantId == request.auth.uid
         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (resource.data.farmerId == request.auth.uid
         || resource.data.restaurantId == request.auth.uid
         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');

      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
      match /reviews/{reviewId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && (get(/databases/$(database)/documents/orders/$(id)).data.farmerId == request.auth.uid
           || get(/databases/$(database)/documents/orders/$(id)).data.restaurantId == request.auth.uid);
        // 6/5 #128: モデレーション（運営が非表示=hidden に）のみ admin に update を許可。
        // 送信後の本人編集は不可（MVP）＝管理者だけが update できる。
        allow update: if request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
    }

    match /reports/{id} {
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      allow update: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /caaPrice/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /caaPriceHistory/{id} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /settings/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 5/24 #82 Phase 2 Chunk 2: 紹介クーポン
    //   create:  Cloud Functions のみ（クライアントからの直接 create は禁止）
    //   read:    所有者または admin（マイページ表示 + admin/referral.html の発行統計）
    //   update:  所有者が usedAt/usedOrderId のみ更新可、かつ usedOrderId が未設定（=未使用）のときのみ
    //   delete:  禁止
    match /coupons/{couponCode} {
      allow read: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid
         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if false;
      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid
        && resource.data.usedOrderId == null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['usedAt', 'usedOrderId']);
      allow delete: if false;
    }

    // 6/26 #171 案B: ウォレット（買い手専用・残高＋台帳）。
    //   書き込みは Cloud Functions（admin SDK＝ルールをバイパス）のみ。
    //   返金クレジット（辞退/キャンセル/問題）・注文使用デビット・出金申請は全て CF 経由。
    //   ＝クライアントが残高を改竄できないようにする（お金の核）。
    match /wallets/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid
         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if false;

      match /transactions/{txId} {
        allow read: if request.auth != null
          && (request.auth.uid == uid
           || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
        allow write: if false;
      }
    }

    match /todos/{uid}/items/{id} {
      allow read: if request.auth.uid == uid;
      allow write: if false;
    }

    match /notifications/{uid}/items/{id} {
      allow read: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid;
      allow create, delete: if false;
    }

    match /carts/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    match /favorites/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    match /counters/{id} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow write: if false;
    }

    // 6/14 #145: 親ドキュメント（lastMessage/hasUnreadFromUser/supportStatus 等のサマリ・状態）。
    //   read:  本人 or admin。
    //   write: admin のみ（functions=admin SDK はルールをバイパス）。状態フィールド supportStatus は
    //          ここに保存される。ユーザー側クライアントは親docを書かない（addDoc は messages サブコレ）。
    //          ユーザーが自分の supportStatus を 'done' にして未対応を隠せないよう write を admin 限定に。
    match /adminChats/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid
         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 6/14 #145: メッセージ（本文・画像・件の区切り system 行）。
    //   read:   本人 or admin。
    //   create: 本人は senderRole=='user'（自分の発言）または senderRole=='system'&&type=='separator'
    //           （件の区切り）のみ＝管理者なりすまし・任意 system 行の偽装を封鎖。admin は任意作成可。
    //   update: 本人は isRead のみ更新可（既読化）。admin は任意。delete は不可。
    match /adminChats/{uid}/messages/{msgId} {
      allow read: if request.auth != null
        && (request.auth.uid == uid
         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if request.auth != null
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
         || (request.auth.uid == uid
             && (request.resource.data.senderRole == 'user'
              || (request.resource.data.senderRole == 'system'
                  && request.resource.data.type == 'separator'))));
      allow update: if request.auth != null
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
         || (request.auth.uid == uid
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])));
    }

    // 6/14 #144: 運営チャット FAQ（よくある質問）
    //   read:  公開（published==true）は誰でも読める（振り分け画面でのユーザー自己解決）。
    //          非公開（下書き＝ネイティブチェック前）は admin のみ。
    //   write: admin のみ（追加/編集/公開非公開/並べ替え/削除）。
    //   ※ユーザー側クエリは where(category==X, published==true)（equality×2・orderByなし）で
    //     複合インデックス不要。並び順 order はクライアントでソート。
    match /faq/{id} {
      allow read: if resource.data.published == true
        || (request.auth != null
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 7/4 #190: 利用規約・プライバシーポリシー（管理画面で運営が編集・ユーザーは公開版のみ read）。
    //   doc id = 'terms' | 'privacy'。フィールド：draft{ja,en,km}{title,body} / pub{...同} /
    //   published(bool) / updatedAt。ユーザーページ（terms.html / privacy.html）は published==true のとき
    //   pub を読む（未ログインの register 新規タブからも読めるよう published 分岐に auth を課さない＝faq と同型）。
    match /legal/{docId} {
      // resource == null＝未作成ドキュメント（運営が未公開の間）を getDoc したときに permission-denied を投げず
      //   「存在しない」を素直に返す＝ユーザーページはフォールバック表示（register 新規タブの未ログイン読取も静か）。
      allow read: if resource == null
        || resource.data.published == true
        || (request.auth != null
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

  }
}
