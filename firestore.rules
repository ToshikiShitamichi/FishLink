rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{path=**}/reviews/{reviewId} {
      allow read: if request.auth != null;
    }

    match /users/{uid} {
      allow read: if true;
      allow create: if request.auth.uid == uid
        && !request.resource.data.keys().hasAny(['isBanned', 'bannedAt', 'bannedReason', 'gaqpCertified', 'gaqpCertifiedAt']);
      // 5/27 #96: 本人は gaqp* を触れない。admin のみ gaqpCertified / gaqpCertifiedAt を更新可
      allow update: if (request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isBanned', 'bannedAt', 'bannedReason', 'gaqpCertified', 'gaqpCertifiedAt']))
        || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['gaqpCertified', 'gaqpCertifiedAt']));
    }

    match /fishListings/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'farmer';

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid;
        // 5/27 #99: listing farmer は全フィールド更新可（既存・replyText 等）
        //          + 多段スレッドで自分の child reply を取り消したいケースのため、
        //          コメント送信者本人は isDeleted / deletedAt のみ更新可
        // 6/3 #119: 質問起点の取り消し（スレッドごと削除）で threadDeleted フラグも許可（送信者本人）。
        //          子返信・legacy返信の連鎖削除はサーバ（functions=admin）が代行。
        // 6/3 #121: 運営（admin）は連絡先マスク発動投稿を「非表示にする」ため全フィールド更新可。
        allow update: if request.auth != null
          && (get(/databases/$(database)/documents/fishListings/$(id)).data.farmerId == request.auth.uid
              || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
              || (resource.data.senderId == request.auth.uid
                  && request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['isDeleted', 'deletedAt', 'threadDeleted'])));
      }
    }

    match /orders/{id} {
      allow read: if request.auth != null
        && (resource.data.farmerId == request.auth.uid
         || resource.data.restaurantId == request.auth.uid
         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (resource.data.farmerId == request.auth.uid
         || resource.data.restaurantId == request.auth.uid
         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');

      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
      match /reviews/{reviewId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && (get(/databases/$(database)/documents/orders/$(id)).data.farmerId == request.auth.uid
           || get(/databases/$(database)/documents/orders/$(id)).data.restaurantId == request.auth.uid);
        // 6/5 #128: モデレーション（運営が非表示=hidden に）のみ admin に update を許可。
        // 送信後の本人編集は不可（MVP）＝管理者だけが update できる。
        allow update: if request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
    }

    match /reports/{id} {
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      allow update: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /caaPrice/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /caaPriceHistory/{id} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /settings/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 5/24 #82 Phase 2 Chunk 2: 紹介クーポン
    //   create:  Cloud Functions のみ（クライアントからの直接 create は禁止）
    //   read:    所有者または admin（マイページ表示 + admin/referral.html の発行統計）
    //   update:  所有者が usedAt/usedOrderId のみ更新可、かつ usedOrderId が未設定（=未使用）のときのみ
    //   delete:  禁止
    match /coupons/{couponCode} {
      allow read: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid
         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if false;
      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid
        && resource.data.usedOrderId == null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['usedAt', 'usedOrderId']);
      allow delete: if false;
    }

    match /todos/{uid}/items/{id} {
      allow read: if request.auth.uid == uid;
      allow write: if false;
    }

    match /notifications/{uid}/items/{id} {
      allow read: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid;
      allow create, delete: if false;
    }

    match /carts/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    match /favorites/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    match /counters/{id} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow write: if false;
    }

    match /adminChats/{uid} {
      allow read, write: if request.auth != null
        && (request.auth.uid == uid
         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    match /adminChats/{uid}/messages/{msgId} {
      allow read, write: if request.auth != null
        && (request.auth.uid == uid
         || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

  }
}
