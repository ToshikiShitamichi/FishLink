rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── 既存ルール（現行 Console と同一・そのまま） ──────────────────

    match /fishListings/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /qr/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /reports/{uid}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null
        && (request.auth.uid == uid
         || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    match /chat/{orderId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /profile/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ✅ voice ブロックは /b/{bucket}/o の中に置く（5/23 #81）
    match /voice/{orderId}/{file=**} {
      allow read: if request.auth != null
        && (firestore.get(/databases/(default)/documents/orders/$(orderId)).data.farmerId == request.auth.uid
         || firestore.get(/databases/(default)/documents/orders/$(orderId)).data.restaurantId == request.auth.uid);
      allow write: if request.auth != null
        && (firestore.get(/databases/(default)/documents/orders/$(orderId)).data.farmerId == request.auth.uid
         || firestore.get(/databases/(default)/documents/orders/$(orderId)).data.restaurantId == request.auth.uid)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
    }

    // ── 6/22 追加：許可リストから漏れていた既存機能のパス ─────────────
    // ⚠️ 現行 Console は許可リスト方式。下記3パスはアプリで実使用しているが
    //    ルールが無く既定で拒否されていた＝画像アップロードが失敗していた。

    // 🔴 #170: 管理FAQ の回答画像（admin/faq.html が faq/{id}/ へアップロード）。
    //   公開FAQの画像は全ユーザーが閲覧（read:true）／書込みは admin のみ（FAQ管理は管理者専用）。
    //   ＝これが無かったため「画像つきFAQ保存が失敗（文字のみOK）」になっていた（#170 の根因）。
    match /faq/{id}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // #145: 運営チャットの添付画像（admin-chat.html がユーザー側で adminChats/{uid}/ へ／
    //   管理側の返信画像も同パス）。本人＝uid、または admin が読み書き（reports と同パターン）。
    match /adminChats/{uid}/{allPaths=**} {
      allow read: if request.auth != null
        && (request.auth.uid == uid
         || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null
        && (request.auth.uid == uid
         || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // #129: 精算の入金控え／送金スクショ（admin/order.html が settlements/{orderId}/ へアップロード）。
    //   運営の照合用＝admin のみ読み書き（一般ユーザーには非公開）。
    match /settlements/{orderId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 🎬 7/9 #199: リール動画（reels/{uid}/{listingId}/{videoId}.ext）。
    //   公開 read（買い手が視聴）／本人（農家）のみ write（自分の動画のみ アップロード/個別削除）。
    //   ⚠ ルール欠落は #170(FAQ)/#179(QR) と同じ「無言のアップロード失敗」を招くため、動画パスを明示する。
    //   動画＝サイズ上限 50MB（節約構成の安全網・アプリ側は ~48MB で弾く）。
    //   🎬 7/15 #205①④: 同パスに「動画の1コマ サムネ（image/jpeg・_thumb.jpg）」も上げる＝画像も許可（5MB上限）。
    //   delete は request.resource が null なので、null 許容で本人削除を通す。
    match /reels/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && (request.resource == null
            || (request.resource.contentType.matches('video/.*') && request.resource.size < 50 * 1024 * 1024)
            || (request.resource.contentType.matches('image/.*') && request.resource.size < 5 * 1024 * 1024));
    }

    // 💳 7/10 #203/#204: 買い手が前払いKHQR画面で添付する「お支払いの控え」画像
    //   （cart.html が paymentProofs/{uid}/ へアップロード・任意）。運営が入金照合で参照。
    //   本人（買い手 uid）のみ write／本人 or admin が read（reports パターン）。画像のみ・5MB上限。
    match /paymentProofs/{uid}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow read: if request.auth != null
        && (request.auth.uid == uid
         || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

  }
}
